<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="452.0" prefWidth="712.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="viewctrl.AudioPlayerController">
    <children>
        <Label fx:id="lblLocalTime" layoutX="26.0" layoutY="30.0" text="Time" />
        <ProgressBar fx:id="pbProgress" layoutX="68.0" layoutY="356.0" prefHeight="20.0" prefWidth="576.0" progress="0.0" />
        <ImageView fx:id="ivImage" fitHeight="171.0" fitWidth="200.0" layoutX="71.0" layoutY="114.0" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="lblSongTime" layoutX="373.0" layoutY="313.0" text="Songpassed/SongTime" />
        <Button fx:id="btnAddSong" layoutX="498.0" layoutY="226.0" mnemonicParsing="false" onAction="#actionAddSong" text="Add Song" />
        <Label fx:id="lblSongTitle" layoutX="373.0" layoutY="285.0" text="SongTitle" />
        <ListView fx:id="lvPlaylist" layoutX="498.0" layoutY="14.0" prefHeight="200.0" prefWidth="200.0" />
      <Button fx:id="btnPlaySong" layoutX="316.0" layoutY="389.0" mnemonicParsing="false" onAction="#actionPlayPause" prefHeight="24.0" prefWidth="40.0" text="⏸" />
      <Button fx:id="btnNext" layoutX="373.0" layoutY="389.0" mnemonicParsing="false" onAction="#actionPrevNext" text="&gt;&gt;" />
      <Button fx:id="btnPrev" layoutX="258.0" layoutY="389.0" mnemonicParsing="false" onAction="#actionPrevNext" text="&lt;&lt;" />
      <Label fx:id="lblSongArtist" layoutX="373.0" layoutY="260.0" text="SongArtist" />
      <Label fx:id="lblSongAlbum" layoutX="373.0" layoutY="230.0" text="SongAlbum" />
    </children>
</AnchorPane>
