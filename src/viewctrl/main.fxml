        <Label fx:id="lblGlobalTime" layoutX="26.0" layoutY="30.0" text="Time" />
        <ProgressBar fx:id="pbProgress" layoutX="71.0" layoutY="381.0" prefHeight="20.0" prefWidth="576.0" progress="0.0" />
        <ImageView fx:id="ivImage" fitHeight="171.0" fitWidth="200.0" layoutX="71.0" layoutY="161.0" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="lblSongTime" layoutX="376.0" layoutY="338.0" text="Songpassed/SongTime" />
        <Button fx:id="btnAddSong" layoutX="498.0" layoutY="226.0" mnemonicParsing="false" onAction="#actionAddSong" text="Add Song" />
        <Label fx:id="lblSongTitle" layoutX="376.0" layoutY="310.0" text="SongTitel" />
        <ListView fx:id="lvPlaylist" layoutX="498.0" layoutY="14.0" prefHeight="200.0" prefWidth="200.0" />
    </children>
</AnchorPane>